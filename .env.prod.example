# ─── Domain ───
DOMAIN=yourdomain.com

# ───# ─── Domain ───
DOMAIN=yourdomain.com

# ─── Database Configuration ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_secure_password_here
POSTGRES_DB=payload
# DATABASE_URL is constructed automatically in docker-compose.prod.yml
# but if you need it locally for testing prod setup:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/payload

# ─── Payload CMS Configuration ───
PAYLOAD_SECRET=generate_a_long_random_secret_here_min_32_chars
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com
CRON_SECRET=generate_a_secure_cron_secret_here
NODE_ENV=production

# ─── Cloudflare R2 Storage ───
R2_BUCKET=your-bucket-name
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Analytics (PostHog) ───
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

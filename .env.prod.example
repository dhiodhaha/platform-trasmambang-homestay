# Database connection string
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/payload


# Or use a PG connection string
#DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests
PREVIEW_SECRET=YOUR_SECRET_HERE


# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=generate_a_secure_password_here
POSTGRES_DB=payload

# Payload CMS Configuration
# DATABASE_URL is constructed automatically in docker-compose.prod.yml
# but if you need it locally for testing prod setup:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/payload

PAYLOAD_SECRET=generate_a_long_random_secret_here
NODE_ENV=production
